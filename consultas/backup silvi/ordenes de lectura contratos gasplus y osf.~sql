SELECT A.ORDER_ID,
A.ORDER_ACTIVITY_ID , 
S.SESUSUSC CONTRATO_OSF,
S.SESUNUSE PRODUCTO_OSF,
SU.SUSCCODIGAS CONTRATO_GASPLUS,
SH.SESUNUSEGAS PRODUCTO_GASPLUS
FROM OR_ORDER R
INNER JOIN OR_ORDER_ACTIVITY A  ON A.ORDER_ID = R.ORDER_ID
INNER JOIN SERVSUSC S ON A.PRODUCT_ID = S.SESUNUSE
INNER JOIN HOMOLOGACION.SERVSUSC_HOMOLOGADO SH ON SH.SESUNUSEOSF = S.SESUNUSE
INNER JOIN HOMOLOGACION.SUSCRIPC_HOMOLOGADO SU ON SU.SUSCCODIOSF  =S.SESUSUSC 
WHERE SESUCICL IN (6012)
 AND R.TASK_TYPE_ID IN (12617)
AND R.ORDER_STATUS_ID  IN (5)
