DECLARE
  job_name VARCHAR2(100);
  job_list SYS.ODCIVARCHAR2LIST := SYS.ODCIVARCHAR2LIST('CIERRE_COMERCIAL', 'CIERRE_UNO', 'CIERRE_DOS');
BEGIN
  FOR i IN 1..job_list.COUNT LOOP
    job_name := job_list(i);
    dbms_scheduler.set_attribute(
                                  job_name,
                                  'INSTANCE_ID',
                                  1  -- Mismo INSTANCE_ID para todos
                                 );
  END LOOP;
  COMMIT;
END;
