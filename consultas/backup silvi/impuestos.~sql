--VALOR IMPUESTOS
SELECT C.CARGCONC , ( C.CARGVALO / (OPEN.DALD_PARAMETER.FNUGETNUMERIC_VALUE('VAL_DIV_LDCGFV'))) *
( OPEN.DALD_PARAMETER.FNUGETNUMERIC_VALUE('VAL_DIV_LDCGFV')) AS VALOR_IMPUESTOS , C.CARGDOSO, C.CARGCACA, CC.CUCOFACT, C.CARGVABl
FROM OPEN.CARGOS   C , FACTURA  F ,CUENCOBR CC
WHERE C.CARGCONC IN (287,137) 
AND C.CARGSIGN = 'DB'
AND C.CARGNUSE = 52174692
AND C.CARGTIPR = 'A'
AND C.CARGDOSO LIKE 'PP-%'
AND C.CARGCUCO > 0
AND CC.CUCOCODI = C.CARGCUCO
AND F.FACTCODI = CC.CUCOFACT
AND CARGVABL > 0 
/*AND F.FACTCODI IN (2098487133)*/;

