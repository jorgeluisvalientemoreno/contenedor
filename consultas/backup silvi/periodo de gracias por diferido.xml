<?xml version="1.0" encoding="utf-8"?><ReportConfiguration xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema"><Name>Registro de Periodos de Gracia por Diferido</Name><Description>Registro de Periodos de Gracia por Diferido</Description><Title>Registro de Periodos de Gracia por Diferido</Title><Statement>SELECT      /*+ use_nl(suscripc pr_product) use_nl(suscripc ge_subscriber)
                use_nl(pr_product ab_address) use_nl(ab_address ge_geogra_location) */
            suscripc.susccodi,
            suscripc.susccicl,
            pr_product.product_id,
            ab_address.address_parsed,
            ge_geogra_location.display_description location_description,
            ab_address.neighborthood_id neighborthood,
            suscripc.suscclie,
            ge_subscriber.subscriber_name,
            ge_subscriber.subs_last_name
  FROM      suscripc,
            pr_product,
            ge_subscriber,
            ab_address,
            ge_geogra_location
 WHERE      suscripc.susccodi = pr_product.subscription_id
   AND      suscripc.suscclie = ge_subscriber.subscriber_id
   AND      pr_product.address_id = ab_address.address_id (+)
   AND      ab_address.geograp_location_id = ge_geogra_location.geograp_location_id (+)
   AND
       EXISTS
       (
           SELECT  /*+ index(diferido ix_dife_nuse)*/
                   'X'
             FROM  diferido
            WHERE  pr_product.product_id = diferido.difenuse
              AND  diferido.difesape &gt; 0
              AND  diferido.difetire = 'D'
       )</Statement><PrintDetail>true</PrintDetail><RowCount>false</RowCount><ReportWidth>338</ReportWidth><ReportColumns><BaseReportColumn><Name>SUSCCODI</Name><Description>Suscripción</Description><DisplayType>0</DisplayType><InternalType>0</InternalType><Length>8</Length><Scale>0</Scale><Criterion>66301163</Criterion><Required>false</Required><UpdateAllowed>true</UpdateAllowed><Multiline>false</Multiline><Group>false</Group><CriterionValue>= 66301163</CriterionValue><DisplayControl>String</DisplayControl></BaseReportColumn><BaseReportColumn><Name>SUSCCICL</Name><Description>Ciclo de Facturación</Description><DisplayType>0</DisplayType><InternalType>0</InternalType><Length>4</Length><Scale>0</Scale><Required>true</Required><UpdateAllowed>true</UpdateAllowed><Multiline>false</Multiline><Group>false</Group><DisplayControl>ListOfValues</DisplayControl><StatementId xsi:type="xsd:long">120000207</StatementId></BaseReportColumn><BaseReportColumn><Name>PRODUCT_ID</Name><Description>Producto</Description><DisplayType>0</DisplayType><InternalType>0</InternalType><Length>15</Length><Scale>0</Scale><Required>false</Required><UpdateAllowed>true</UpdateAllowed><Multiline>false</Multiline><Group>false</Group><DisplayControl>String</DisplayControl></BaseReportColumn><BaseReportColumn><Name>ADDRESS_PARSED</Name><Description>Dirección de Instalación</Description><DisplayType>2</DisplayType><InternalType>2</InternalType><Length>200</Length><Scale>0</Scale><Required>false</Required><UpdateAllowed>false</UpdateAllowed><Multiline>false</Multiline><Group>false</Group><DisplayControl>String</DisplayControl></BaseReportColumn><BaseReportColumn><Name>LOCATION_DESCRIPTION</Name><Description>Localidad</Description><DisplayType>2</DisplayType><InternalType>2</InternalType><Length>400</Length><Scale>0</Scale><Required>false</Required><UpdateAllowed>false</UpdateAllowed><Multiline>false</Multiline><Group>false</Group><DisplayControl>String</DisplayControl></BaseReportColumn><BaseReportColumn><