INSERT INTO open.ic_clascore
    (clcrcons, 
    clcrcorc, 
    clcrclco, 
    clcrcrit, 
    clcrfecr, 
    clcrusua, 
    clcrterm, 
    clcrprog)
SELECT
    sq_ic_clascore_clcrcons.NEXTVAL,
    c.corccons,
    g.clas_contable,
    'AND MOVIITEM =' || g.items,
    SYSDATE,
    usuario,
    terminal,
    'ICRC'
FROM open.ic_confreco c
INNER JOIN temp_clasificadoresGDGU g  ON g.comprobantecod = c.corccoco
WHERE c.corccoco = codigo_id   AND c.corctimo = 63;
  
INSERT INTO OPEN.ic_crcoreco
SELECT  sq_ic_crcoreco_ccrccons.nextval AS ccrccons,
          ca.clcrcorc AS ccrccorc,
          ca.clcrcons AS ccrcclcr,
          'MOVIITEM',
          '=',
          g.items,
          SYSDATE,
          usuario,
          terminal,
          'ICRC'
FROM OPEN.ic_clascore ca
INNER JOIN open.ic_confreco c ON ca.clcrcorc = c.corccons
INNER JOIN temp_clasificadoresGDGU g  ON g.comprobantecod = c.corccoco
WHERE c.corccoco = codigo_id  ; 

COMMIT ; 

END;


