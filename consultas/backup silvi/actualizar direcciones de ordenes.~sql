DECLARE

 NEW_GEOGRA    AB_ADDRESS.GEOGRAP_LOCATION_ID%TYPE :=9104 ; 
 NEW_NEIGH     AB_ADDRESS.NEIGHBORTHOOD_ID%TYPE  :=9107; 
 NEW_X         AB_ADDRESS.SHAPE.SDO_POINT.X%TYPE := -72.445432 ; 
 NEW_Y         AB_ADDRESS.SHAPE.SDO_POINT.Y%TYPE := 11.772369; 
 NEW_CICLO     AB_SEGMENTS.CICLCODI%TYPE := 9015;
 NEW_SECTOR    AB_SEGMENTS.OPERATING_SECTOR_ID%TYPE := 9106;
 

  CURSOR GET_ADDRESS IS
  SELECT DISTINCT (R.EXTERNAL_ADDRESS_ID ) AS ADDRESS_ID
  FROM OR_ORDER R  
  WHERE ORDER_ID IN (SELECT DISTINCT ( ID_ORDEN)
                     FROM GE_DETALLE_ACTA 
                     WHERE ID_ACTA = 250613) ; 
 
 
 BEGIN
   
  FOR REC IN GET_ADDRESS LOOP
   UPDATE AB_ADDRESS A
     SET GEOGRAP_LOCATION_ID= NEW_GEOGRA,
         A.NEIGHBORTHOOD_ID= NEW_NEIGH,
         A.SHAPE.SDO_POINT.X= NEW_X ,
         A.SHAPE.SDO_POINT.Y= NEW_Y
   WHERE ADDRESS_ID = REC.ADDRESS_ID ;

  END LOOP;
  
  FOR REC IN GET_ADDRESS LOOP
    UPDATE AB_SEGMENTS A
      SET CICLCODI=NEW_CICLO,
          CICOCODI=NEW_CICLO,
          OPERATING_SECTOR_ID=NEW_SECTOR,
          A.NEIGHBORHOOD_ID=NEW_NEIGH,
          GEOGRAP_LOCATION_ID=NEW_GEOGRA
    WHERE SEGMENTS_ID IN (SELECT SEGMENT_ID 
                           FROM AB_ADDRESS
                           WHERE ADDRESS_ID  = REC.ADDRESS_ID);

  END LOOP; 
  

    
END ; 
