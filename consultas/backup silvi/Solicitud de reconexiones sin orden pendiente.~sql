SELECT cp.product_id, cp.component_id, cp.component_type_id, cp.component_status_id, 
       (select ps.description 
          from open.ps_product_status ps 
         where ps.product_status_id=cp.component_status_id 
           and ps.prod_status_type_id=2) descestcomp
  from open.pr_component cp
 where cp.product_id = &nuse;
 
select p.*
  from open.pr_comp_suspension p
  where p.component_id in (SELECT cp.component_id
                             from open.pr_component cp
                            where cp.product_id = &nuse);


select p.package_id, m.motive_id,a.product_id, p.request_date, p.attention_date, p.package_type_id,
       pt.description descsoli,
       p.motive_status_id,
       (select ms.description from open.ps_motive_status ms where ms.motive_status_id=p.motive_status_id) descestsoli,
       o.order_id, o.task_type_id,
       (select tt.description from open.or_task_type tt where tt.task_type_id=o.task_type_id) desctt,
       o.created_date, o.legalization_date, o.order_status_id,
       (select os.description from open.or_order_status os where os.order_status_id=o.order_status_id) descestaor,
       o.causal_id || ' - '  || (select gc.description || ' - ' || cc.description
                                from open.ge_Causal gc , open.GE_CLASS_CAUSAL cc 
                               where gc.causal_id = o.causal_id
                                 and gc.class_causal_id = cc.class_causal_id) desccaus
  from open.mo_packages p
left outer join open.ps_package_type pt on (pt.package_type_id=p.package_type_id)
left outer join open.or_order_Activity a on (a.package_id=p.package_id)
left outer join open.or_order o on (o.order_id = a.order_id)
left outer join open.mo_motive m on (m.package_id=p.package_id)
where m.product_id=&nuse
  --and p.package_type_id = 100287;                        
and (upper( pt.description) like '%SUSP%' or upper(pt.description) like '%RECO%');

