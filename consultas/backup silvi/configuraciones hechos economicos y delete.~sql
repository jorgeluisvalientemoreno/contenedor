SELECT J.*  , i.DESCRIPTION
FROM  OPEN.IC_COMPCONT A
INNER JOIN OPEN.IC_CONFRECO CO ON   A.COCOCODI=CO.CORCCOCO
INNER JOIN OPEN.IC_CLASCORE F ON CO.CORCCONS=F.CLCRCORC
INNER JOIN OPEN.IC_CRCORECO J ON J.CCRCCLCR=F.CLCRCONS 
INNER JOIN OPEN.GE_ITEMS I ON TO_CHAR(I.ITEMS_ID) = TO_CHAR(J.CCRCVALO)
WHERE CO.CORCCOCO = 4
AND UPPER(DESCRIPTION) NOT LIKE '%RETEICA%'; --SUBSTR(i.DESCRIPTION, 1, INSTR(i.DESCRIPTION, '-') - 1)

