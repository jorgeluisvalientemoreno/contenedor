--BUSQUEDA DE PRODUCTO Y DPTO
SELECT  P.SUBSCRIPTION_ID ,ge.geograp_location_id , P.PRODUCT_ID,  GE.DISPLAY_DESCRIPTION , SE.SESUESCO , SE.SESUESFN                                                                         
FROM AB_ADDRESS A 
INNER JOIN  PR_PRODUCT P  ON  P.ADDRESS_ID = A.ADDRESS_ID
INNER JOIN SERVICIO S ON S.SERVCODI = P.PRODUCT_TYPE_ID
INNER JOIN SERVSUSC  SE ON S.SERVCODI = SE.SESUSERV
INNER JOIN GE_GEOGRA_LOCATION GE ON GE.GEOGRAP_LOCATION_ID = A.GEOGRAP_LOCATION_ID
WHERE GE.DISPLAY_DESCRIPTION LIKE '%ATLANTICO%' 
AND   SE.SESUESFN = 'M' 
AND SE.SESUESCO= 1
AND P.SUBSCRIPTION_ID= 1036926
GROUP BY ( P.SUBSCRIPTION_ID , P.PRODUCT_ID,  GE.DISPLAY_DESCRIPTION , SE.SESUESCO , SE.SESUESFN,ge.geograp_location_id  ) ;
