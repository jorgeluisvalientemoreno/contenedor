-- porcentaje de subsidio PARA CONCEPTO 196
select SUM(ralivasu) * 100 / SUM(ralivaul) as porcentaje_subsidio
from rangliqu , 
cargos  c
where ralisesu = 50980704
AND ralivasu > 0
and ralisesu = c.cargnuse 
and  ralipefa = c.cargpefa
and c.cargpefa = 99413; 

 --Porcentaje concepto 196
