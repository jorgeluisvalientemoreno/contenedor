        ta_rangvitc.ravtporc
 from open.ta_conftaco t
 left join open.ta_tariconc ta on cotccons= tacocotc
 left join  open.ta_vigetaco on tacocons = vitctaco
 left join open.concepto c on cotcconc = c.conccodi
 left join open.ta_rangvitc on ravtvitc = vitccons
 where cotcconc in (19,30,674)
   and cotcserv =7014 
   and cotcvige = 'S' 
   and sysdate between vitcfein and vitcfefi 
   and tacocr01=4 and tacocr02 in (1,-1) ;
 

SELECT tacocr01 commercialPlanId, cotcconc conceptId, c.CONCDESC concept, vitcvalo value , tacocr03 subcateg , tacocr02 mercarele, tacocr04 categ
 FROM open.ta_tariconc a
          LEFT OUTER JOIN open.ta_conftaco b ON (a.tacocotc = b.cotccons)
          LEFT OUTER JOIN open.ta_vigetaco d ON (d.vitctaco = a.tacocons)
          LEFT OUTER JOIN open.ta_rangvitc e ON (e.ravtvitc = d.vitccons)
          INNER JOIN open.concepto c on c.conccodi = cotcconc AND c.conccodi in (30, 19, 674)
 WHERE cotcserv = 7014
   AND tacocr01 = 4
  -- AND tacocr03 in (1, -1)
  and sysdate between vitcfein and vitcfefi ; 
  
  

