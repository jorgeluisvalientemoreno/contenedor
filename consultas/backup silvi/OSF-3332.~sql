--productos_con_cuentas_de_cobro_pendientes
select pr.product_type_id "Tipo Producto",
       sesususc "Contrato",
       sesunuse "Producto",
       sesuesfn  "Estado_finan",
       s.sesuesco || ' -' || initcap(substr(e.escodesc,1,19)) "Estado de corte",
       (select count(distinct(br.cucocodi))
        from cuencobr br,
        cargos c
         where br.cuconuse = sesunuse
         and   br.cucocodi = c.cargcuco
         and cucosacu > 0 )"Cant_cuentas_cobro" ,
       (select nvl((sum(cucosacu) - sum(cucovare) - sum(cucovrap)), 0)
          from cuencobr br
         where br.cuconuse = sesunuse) "Saldo_Pendiente"
from servsusc s
inner join pr_product pr on s.sesunuse = pr.product_id
left join estacort e on e.escocodi= s.sesuesco
where  not  exists ( select null
                   from cuencobr
                   where cuconuse= sesunuse
                   and cucosacu>0)
and sesuesco = 1
and rownum <=50;

select cargcuco , cargnuse , cargconc,cargcaca , co.concdesc, co.concticl , cargsign , cargpefa, cargvalo,cargvabl , cargdoso, cargcodo, cargusua, cargtipr, cargfecr , cargprog
from cuencobr br
inner join cargos c on cargcuco = cucocodi
left join concepto co on conccodi= cargconc
where  cargnuse = 14518626 and cargfecr >= trunc(sysdate)
order by cargfecr desc;

select *
from cuencobr, factura
where cucofact = factcodi 
and cuconuse = 14518870  and factfege >=trunc(sysdate);

select *
from AUDITORIA_MANOT  
where fecha>= trunc(sysdate);
