
SELECT a.max_budget , GE_PERSON.USER_ID , MASK , ACTION_AMOUNT_ID 
FROM GE_PERSON , GE_FINANCIAL_PROFILE a , OPEN.SA_USER S 
WHERE GE_PERSON.USER_ID = ( SELECT S1.USER_ID FROM SA_USER S1 WHERE MASK LIKE '%DIASAL%') 
AND a.POSITION_TYPE_ID = GE_PERSON.POSITION_TYPE_ID AND S.USER_ID = GE_PERSON.USER_ID 
