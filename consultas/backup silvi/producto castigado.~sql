SELECT * 
FROM LDC_OSF_SESUCIER l
WHERE l.nuano = 2022
AND l.sesusape = 0
AND l.estado_financiero = 'C'
AND l.numes = 04
AND EXISTS (select null
from open.ciclo
left join open.pericose pc on pc.pecscico=ciclcodi and sysdate between pc.pecsfeci and pc.pecsfecf
left join open.perifact pf on pf.pefacicl=ciclcodi and sysdate between pf.pefafimo and pf.pefaffmo
where ciclcico = l.ciclo
and pefaactu = 'S')
and l.tipo_producto = 7055
AND NOT EXISTS (SELECT NULL
FROM or_order o
INNER JOIN or_order_activity t on o.order_id = t.order_id
WHERE t.product_id = L.PRODUCTO
AND o.task_type_id = 50005 AND 
 o.order_status_id IN (0,5))
 



SELECT t.subscription_id , t.product_id, o.order_id , o.task_type_id ,o.created_date,exec_initial_date, 
       execution_final_date , o.order_status_id as Status
  FROM or_order o
  INNER JOIN or_order_activity t on o.order_id = t.order_id
  WHERE  o.task_type_id = 5005
  AND o.order_status_id in (0,5)
  AND o.created_date > '01/01/2022'
  ORDER BY o.created_date DESC


SELECT t.subscription_id , t.product_id, o.order_id , o.task_type_id  ,exec_initial_date, 
       execution_final_date , o.order_status_id as Status, o.created_date
  FROM or_order o
  INNER JOIN or_order_activity t on o.order_id = t.order_id
  WHERE  o.task_type_id = 5005
   AND o.created_date > '01/01/2022'
   AND o.order_status_id in (0,5)
  AND  t.product_id in (17193604,17194636,41000169,17187139,6600237,6634576,1503664);
  
  
