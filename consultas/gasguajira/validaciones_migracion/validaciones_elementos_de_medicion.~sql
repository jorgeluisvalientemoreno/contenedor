WITH BASE AS ( 
    SELECT S.SESUNUSEGAS PRODUCTOGASPLUS,
           PRODUCT_ID PRODUCTO_OSF,
           SUBSCRIPTION_ID CONTRATO_OSF,
           PRODUCT_STATUS_ID
    FROM MIGRAGG.PR_PRODUCT PR  
    INNER JOIN HOMOLOGACION.SERVSUSC_HOMOLOGADO S  ON PRODUCT_ID = S.SESUNUSEOSF 
    WHERE PR.PRODUCT_TYPE_ID = 7014
      AND PRODUCT_STATUS_ID IN (1,2)
      AND NOT EXISTS (
            SELECT NULL 
            FROM MIGRAGG.ELMESESU
            WHERE EMSSSESU = PRODUCT_ID )
),

INFO_GASGG AS (

    SELECT *
    FROM (
        SELECT BASE.PRODUCTOGASPLUS,
               BASE.PRODUCTO_OSF,
               BASE.CONTRATO_OSF,
               BASE.PRODUCT_STATUS_ID,
               L.LECTMEDI MEDIDOR_GASPLUS,
               ROW_NUMBER() OVER (
                   PARTITION BY BASE.PRODUCTOGASPLUS
                   ORDER BY L.LECTFECH DESC
               ) RN
        FROM GASGG.LECTURA L
        INNER JOIN BASE ON L.LECTNUSE = BASE.PRODUCTOGASPLUS
        INNER JOIN GASGG.MEDIDOR M ON L.LECTMEDI = M.MEDINUSE
        WHERE M.MEDIESME IN (2,3)
    )
    WHERE RN = 1
)

SELECT *
FROM INFO_GASGG;

