--se recomienda consultar por unidad e item
select m.operating_unit_id,
       origen.name,
       s.serie,
       d.fecha,
       origen.oper_unit_classif_id,
       origen.oper_unit_status_id,
       (select oous.description
          from OPEN.OR_OPER_UNIT_STATUS oous
         where oous.oper_unit_status_id = origen.oper_unit_status_id) desc_estatus_orien,
       m.items_id,
       i.description desc_item,
       i.item_classif_id,
       m.uni_item_bala_mov_id,
       m.move_date,
       decode(m.movement_type,
              'I',
              'INCREMENTO',
              'D',
              'DECREMENTO',
              'N',
              'NEUTRO') tipo_movimiento,
       m.item_moveme_caus_id,
       (select oimc.description
          from OPEN.OR_ITEM_MOVEME_CAUS oimc
         where oimc.item_moveme_caus_id = m.item_moveme_caus_id) desc_movi,
       m.amount cantidad,
       m.total_value,
       m.valor_venta,
       m.terminal,
       m.user_id,
       m.support_document,
       m.target_oper_unit_id,
       dest.name,
       dest.oper_unit_classif_id,
       dest.oper_unit_status_id,
       (select oous.description
          from OPEN.OR_OPER_UNIT_STATUS oous
         where oous.oper_unit_status_id = dest.oper_unit_status_id) desc_estatus_dest,
       m.id_items_seriado,
       s.serie,
       s.id_items_estado_inv,
       s.operating_unit_id unidad_serial,
       m.id_items_documento,
       d.document_type_id,
       (select gdt.description
          from OPEN.GE_DOCUMENT_TYPE gdt
         where gdt.document_type_id = d.document_type_id) desc_docu_type,
       d.documento_externo,
       d.estado,
       d.comentario,
       d.terminal_id,
       d.user_id
  from open.or_uni_item_bala_mov m
 inner join open.ge_items i
    on i.items_id = m.items_id
 inner join open.or_operating_unit origen
    on origen.operating_unit_id = m.operating_unit_id
 inner join open.or_operating_unit dest
    on dest.operating_unit_id = m.target_oper_unit_id
 inner join open.ge_items_documento d
    on d.id_items_documento = m.id_items_documento
 inner join open.ge_items_seriado s
    on s.id_items_seriado = m.id_items_seriado
   and s.serie in ('T-20900343-2009',
                   '982912',
                   'N-602198',
                   'R-982908',
                   'N-20502603V',
                   'N-20503117',
                   'J-20661',
                   'O-1038370-2010',
                   'W-352750')
 order by s.serie, m.id_items_seriado, d.fecha desc
