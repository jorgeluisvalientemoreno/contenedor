--Configuracion tarifa por concepto
select tc.*, rowid from open.ta_conftaco tc where tc.cotcconc = 30;

--Tarifa pro concepto
select ta.*, rowid
  from open.ta_tariconc ta
 where 1 = 1
   and ta.tacocotc in
       (select tc.cotccons from open.ta_conftaco tc where tc.cotcconc = 30);

--Vigencia de concepto
select tv.*, rowid
  from open.ta_vigetaco tv
 where tv.vitctaco in
       (select ta.tacocons
          from open.ta_tariconc ta
         where 1 = 1
           and ta.tacocotc in (select tc.cotccons
                                 from open.ta_conftaco tc
                                where tc.cotcconc = 30)
           and tacocr01 = 4 --PLAN_COME
        --and tacocr02 = 2--SUBCATEGORIA
        --and tacocr03 = 1--CATEGORIA
        )
 order by tv.vitcfefi desc;

select * from open.concepto c;

select cotcconc,
       cotcserv,
       cotcvige,
       tacocr01 PLAN_COME,
       tacocr02 SUBCATEGORIA,
       tacocr03 CATEGORIA,
       vitctaco,
       vitccons,
       vitcfein,
       vitcfefi,
       vitcvalo,
       vitcporc
  from ta_conftaco t
  left join ta_tariconc ta
    on cotccons = tacocotc
  left join open.ta_vigetaco
    on tacocons = vitctaco
  left join open.concepto c
    on cotcconc = c.conccodi
 where cotcconc in (19)
   and cotcserv = 7014
   and cotcvige = 'S'
   and vitcfefi >= '01/12/2024';

