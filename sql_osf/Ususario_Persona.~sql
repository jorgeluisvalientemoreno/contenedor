--Persona y Mascara OSF
select a.person_id || ' - ' || a.name_ FUNCIONARIO,
       b.user_id || ' - ' || b.mask USUARIO
  from open.ge_person a
 inner join open.sa_user b
    on a.user_id = b.user_id
   and 1 = 1
      -- and b.user_id = 49182
      --and upper(a.name_) like upper('%consbell4%')
      --and upper(b.mask) = upper('consbell4');
   and a.person_id = 49182
 order by a.person_id;

--Solo Persona
select a.person_id || ' - ' || a.name_ FUNCIONARIO
  from open.ge_person a
 where 1 = 1
   and a.person_id = 49182
 order by a.person_id;

--Solo Mascara
select b.user_id || ' - ' || b.mask USUARIO
  from sa_user b
 where 1 = 1
--and b.user_id = 49182
--and upper(b.mask) = upper('consbell4');
 order by b.user_id;
